# Root environment variables for docker-compose.yml
#
# Copy this file to .env and fill in your values before running docker compose.
# All six domains must point to this host machine (DNS A records or /etc/hosts).

# Contact email for Let's Encrypt certificate issuance (required for HTTPS).
EMAIL=admin@example.com

# Main shop domain (the full-stack Nuxt app).
MAIN_DOMAIN=store.yourdomain.com

# Project/documentation site domain (static Nuxt site).
PROJECT_DOMAIN=project.yourdomain.com

# Third-party font service domain (serves the Inter font stylesheet).
FONT_DOMAIN=font.yourdomain.com

# Third-party video/cloud storage domain (hosts the trailer video).
VIDEO_DOMAIN=video.yourdomain.com

# Third-party audience/tracking service domain (receives tracking POST requests).
TRACKING_DOMAIN=tracking.yourdomain.com

# Third-party form service domain (receives leaky form data).
FORM_DOMAIN=forms.yourdomain.com
