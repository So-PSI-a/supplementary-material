# Environment variables for the shop application (challenge/).
#
# Copy this file to challenge/.env and fill in your values.
# These must match the domain values set in the root .env.

# Domain (without protocol) under which the shop itself is running.
# Used for Open Graph meta tags and cookie configuration.
PUBLIC_MAIN_DOMAIN=store.yourdomain.com

# URL to the font stylesheet served by the third-party font service.
# The shop loads this in <head> — requests go to a separate domain (privacy problem H3).
PUBLIC_FONT_URL=https://font.yourdomain.com/inter.css

# URL to the Plausible analytics script.
# The script tag receives a data-domain attribute equal to PUBLIC_MAIN_DOMAIN.
# Leave unset to disable analytics without affecting any other functionality.
#PUBLIC_PLAUSIBLE_SCRIPT=https://analytics.yourdomain.com/plausible.js

# URL to the trailer video hosted on the third-party cloud storage service.
# Embedded as an iframe on the shop homepage (privacy problem H2).
PUBLIC_STONED_PIRANHA_VIDEO_URL=https://video.yourdomain.com/stoned-piranha-trailer.mp4

# Endpoint URL for the leaky forms service.
# Form field data is sent here on every keystroke before submission (privacy problem H5).
PUBLIC_LEAKY_FORMS_ENDPOINT=https://forms.yourdomain.com

# Endpoint URL for the user interaction tracking service.
# User actions are POSTed here for tracking purposes (privacy problem H4).
PUBLIC_TRACKING_ENDPOINT=https://tracking.yourdomain.com

# PostgreSQL connection string.
# When running via docker-compose, use the service name (db) as the host.
DATABASE_URL=postgres://postgres:postgres@db:5432/privatepiranha
POSTGRES_URL=postgres://postgres:postgres@db:5432/privatepiranha

# Secret used to encrypt session cookies (nuxt-auth-utils).
# Must be at least 32 characters. Generate one with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=replace-this-with-a-random-32-plus-character-string
